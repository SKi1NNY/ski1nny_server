APP_NAME=Skinny API
APP_VERSION=0.1.0
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=skinny
POSTGRES_PASSWORD=skinny
POSTGRES_DB=skinny
DATABASE_URL=postgresql+psycopg2://skinny:skinny@postgres:5432/skinny

REDIS_URL=redis://redis:6379/0

ANTHROPIC_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=skinny-ingredients
PINECONE_ENVIRONMENT=us-east-1
OCR_PROVIDER=google-ml-kit
